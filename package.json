{
  "name": "eslint-plugin-no-indexed-access-prop",
  "version": "0.1.2",
  "description": "ESLint and Oxlint plugin that forbids TypeScript indexed access property types.",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "oxlint",
    "typescript",
    "indexed-access",
    "typescript-eslint"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ValTM/eslint-plugin-no-indexed-access-prop.git"
  },
  "bugs": {
    "url": "https://github.com/ValTM/eslint-plugin-no-indexed-access-prop/issues"
  },
  "homepage": "https://github.com/ValTM/eslint-plugin-no-indexed-access-prop#readme",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist-cjs/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    },
    "./rules/no-indexed-access-prop": {
      "types": "./dist/rules/no-indexed-access-prop.d.ts",
      "import": "./dist/rules/no-indexed-access-prop.js",
      "require": "./dist-cjs/rules/no-indexed-access-prop.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "dist-cjs"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepack": "npm run build",
    "publish:login": "npm login --registry https://registry.npmjs.org --userconfig ./.npmrc.publish",
    "publish:whoami": "npm --registry https://registry.npmjs.org --userconfig ./.npmrc.publish whoami",
    "publish:bootstrap:dry-run": "npm --registry https://registry.npmjs.org --userconfig ./.npmrc.publish publish --dry-run",
    "publish:bootstrap": "npm --registry https://registry.npmjs.org --userconfig ./.npmrc.publish publish",
    "release:bump:patch": "node scripts/release.mjs bump patch",
    "release:bump:minor": "node scripts/release.mjs bump minor",
    "release:bump:major": "node scripts/release.mjs bump major",
    "release:bump:patch:dry-run": "node scripts/release.mjs bump patch --dry-run",
    "release:bump:minor:dry-run": "node scripts/release.mjs bump minor --dry-run",
    "release:bump:major:dry-run": "node scripts/release.mjs bump major --dry-run",
    "release:tag-current": "node scripts/release.mjs tag-current",
    "release:tag-current:dry-run": "node scripts/release.mjs tag-current --dry-run",
    "release:github-current": "node scripts/release.mjs github-current",
    "release:github-current:dry-run": "node scripts/release.mjs github-current --dry-run",
    "test:unit": "node --test tests/no-indexed-access-prop.test.mjs tests/commonjs-interop.test.mjs",
    "test:oxlint": "node --test tests/oxlint-smoke.test.mjs",
    "test": "npm run build && npm run test:unit && npm run test:oxlint"
  },
  "peerDependencies": {
    "eslint": ">=8"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.58.2",
    "@typescript-eslint/rule-tester": "^8.58.2",
    "@typescript-eslint/utils": "^8.58.2",
    "eslint": "^10.2.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.2"
  }
}
